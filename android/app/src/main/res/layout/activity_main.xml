<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ClawFace"
            android:textColor="@color/glass_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Permission warning -->
        <TextView
            android:id="@+id/tvPermissionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_overlay_required"
            android:textColor="#FFAA00"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantPermission"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_grant_permission"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Control Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:background="@drawable/glass_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/btn_start"
                    style="@style/Widget.ClawFace.Button.Glass"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/btn_stop"
                    style="@style/Widget.ClawFace.Button.Glass"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Emotions Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmotions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:background="@drawable/glass_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EMOTIONS"
                    android:textColor="@color/glass_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp" />

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNeutral"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Neutral"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnJoy"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Joy"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnxiety"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Anxiety"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnvy"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Envy"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmbarrassment"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Embarr"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnnui"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Ennui"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisgust"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Disgust"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFear"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Fear"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnger"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Anger"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSadness"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Sadness"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:background="@drawable/glass_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MODE"
                    android:textColor="@color/glass_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeActive"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Active"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeStandby"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Standby"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeThinking"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Thinking"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeOffline"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Offline"
                        style="@style/Widget.ClawFace.Button.Glass" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Network Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:background="@drawable/glass_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NETWORK"
                    android:textColor="@color/glass_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/etHost"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="2"
                        android:hint="192.168.1.100"
                        android:textColor="@color/glass_text_primary"
                        android:textColorHint="@color/glass_text_tertiary"
                        android:textSize="13sp"
                        android:background="@drawable/glass_button_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="text"
                        android:singleLine="true"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/etPort"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="9527"
                        android:textColor="@color/glass_text_primary"
                        android:textColorHint="@color/glass_text_tertiary"
                        android:textSize="13sp"
                        android:background="@drawable/glass_button_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="number"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConnect"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Connect"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisconnect"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Disconnect"
                        style="@style/Widget.ClawFace.Button.Glass"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvConnectionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: Disconnected"
                    android:textColor="@color/glass_text_tertiary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Parameters Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:background="@drawable/glass_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PARAMETERS"
                    android:textColor="@color/glass_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="4dp" />

                <include layout="@layout/slider_item" android:id="@+id/sliderEyeScaleY" />
                <include layout="@layout/slider_item" android:id="@+id/sliderEyeTilt" />
                <include layout="@layout/slider_item" android:id="@+id/sliderEyeSquint" />
                <include layout="@layout/slider_item" android:id="@+id/sliderPupilOffsetX" />
                <include layout="@layout/slider_item" android:id="@+id/sliderMouthCurve" />
                <include layout="@layout/slider_item" android:id="@+id/sliderMouthWidth" />
                <include layout="@layout/slider_item" android:id="@+id/sliderMouthOpen" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
