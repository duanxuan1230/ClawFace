<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ClawFace" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- Glass morphism button style -->
    <style name="Widget.ClawFace.Button.Glass" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:background">@drawable/glass_button_bg</item>
        <item name="android:textColor">@color/glass_text_primary</item>
        <item name="android:textSize">10sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
</resources>
